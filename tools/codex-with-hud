#!/usr/bin/env sh
set -eu

SESSION_NAME="${CODEX_HUD_SESSION:-codex-hud}"
WORKDIR="${1:-$(pwd)}"
HUD_HEIGHT="${CODEX_HUD_HEIGHT:-5}"

if ! command -v tmux >/dev/null 2>&1; then
  echo "codex-with-hud requires tmux." >&2
  exit 1
fi

if ! command -v codex >/dev/null 2>&1; then
  echo "codex-with-hud requires codex in PATH." >&2
  exit 1
fi

SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
  TARGET=$(readlink "$SOURCE")
  case "$TARGET" in
    /*) SOURCE="$TARGET" ;;
    *) SOURCE="$DIR/$TARGET" ;;
  esac
done
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
HUD_CMD="node '$SCRIPT_DIR/codex-hud.mjs' --watch --color"

if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  exec tmux attach-session -t "$SESSION_NAME"
fi

tmux new-session -d -s "$SESSION_NAME" -c "$WORKDIR" "codex"
tmux split-window -v -l "$HUD_HEIGHT" -t "$SESSION_NAME":0 -c "$WORKDIR" "$HUD_CMD"
tmux select-pane -t "$SESSION_NAME":0.0
exec tmux attach-session -t "$SESSION_NAME"
